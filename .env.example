# Token del bot de Telegram (obtenido con @BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# Clave secreta para firmar sesiones de Flask
SECRET_KEY=cambia-esta-clave-en-produccion

# Credenciales del panel administrador
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu_contrasena_aqui

# Indice de camara para el stream de video (0, 1, 2...)
# En GCP u otros servidores sin camara, se ignora automaticamente
CAMERA_INDEX=0
